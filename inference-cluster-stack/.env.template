# Node identity (set hostname on the server itself, not here)
NODE_NAME=inference-node
# e.g. inference-dc-a or inference-dc-b

# Model path (mounted from bulk SSD storage)
MODEL_DIR=/data/models
# Switch between models by changing MODEL_NAME:
#   /models/llama-4-scout    (for Llama 4 Scout 109B)
#   /models/qwen3-vl-235b    (for Qwen3-VL 235B-A22B)
MODEL_NAME=/models/llama-4-scout

# Precision: auto (FP16), float16, bfloat16, or half
DTYPE=auto

# Ports
VLLM_PORT=8000
HAPROXY_PORT=8080
HAPROXY_STATS_PORT=8404
ZOT_PORT=5000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
DCGM_PORT=9400

# vLLM parallelism (PCIe: use PP=2, TP=1. NVLink: swap to TP=2, PP=1)
TENSOR_PARALLEL_SIZE=1
PIPELINE_PARALLEL_SIZE=2

# Memory and performance tuning
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=64
